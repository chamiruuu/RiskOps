{
  "name": "riskops-tms",
  "private": true,
  "version": "0.0.17",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "RiskOps",
  "description": "RiskOps Ticket Management System",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/validate-env.cjs && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install",
    "preview": "vite preview",
    "validate-env": "node scripts/validate-env.cjs",
    "electron:dev": "vite build && electron .",
    "electron:build": "node scripts/validate-env.cjs && vite build && electron-builder --win",
    "electron:build:mac": "node scripts/validate-env.cjs && vite build && electron-builder --mac",
    "electron:build:portable": "node scripts/validate-env.cjs && vite build && electron-builder --win --config.win.target=portable",
    "electron:build:nsis": "node scripts/validate-env.cjs && vite build && electron-builder --win --config.win.target=nsis",
    "electron:build:dir": "node scripts/validate-env.cjs && vite build && electron-builder --win --dir",
    "electron:publish": "node scripts/validate-env.cjs && vite build && electron-builder --win --publish always",
    "publish": "node scripts/publish-release.js"
  },
  "build": {
    "appId": "com.riskops.icdro",
    "productName": "RiskOps",
    "afterPack": "scripts/after-pack-sign-mac.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico",
      "artifactName": "RiskOps-TMS-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/icon.icns",
      "artifactName": "RiskOps-TMS-${version}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "chamiruuu",
        "repo": "RiskOps"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RiskOps TMS",
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.96.0",
    "@tailwindcss/postcss": "^4.1.18",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.574.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "supabase": "^2.76.9",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
