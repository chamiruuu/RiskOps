{
  "name": "riskops-tms",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "RiskOps",
  "description": "RiskOps Ticket Management System",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win",
    "electron:build:portable": "vite build && electron-builder --win --config.win.target=portable",
    "electron:build:nsis": "vite build && electron-builder --win --config.win.target=nsis",
    "electron:build:dir": "vite build && electron-builder --win --dir",
    "electron:publish": "vite build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.riskops.tms",
    "productName": "RiskOps TMS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "RiskOps-TMS-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "chamiruuu",
        "repo": "RiskOps"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RiskOps TMS"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.96.0",
    "@tailwindcss/postcss": "^4.1.18",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.574.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "supabase": "^2.76.9",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  }
}
